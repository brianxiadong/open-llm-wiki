# LLM 配置（对话/生成）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=16384

# Embedding 模型（向量化，可与 LLM 使用不同的服务）
EMBEDDING_API_BASE=http://your-embedding-server:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

# Qdrant 向量数据库
QDRANT_URL=http://your-qdrant-server:6333

# RAG 检索参数
# Chunk 切分（字符）
RAG_CHUNK_MIN=400
RAG_CHUNK_MAX=1200
RAG_CHUNK_OVERLAP=80
# 召回（取 Top-K 后再融合/过滤）
RAG_CHUNK_TOP_K=12
RAG_FACT_TOP_K=12
# 低于阈值的向量命中会被丢弃（cosine 相似度）
RAG_CHUNK_SCORE_THRESHOLD=0.35
RAG_FACT_SCORE_THRESHOLD=0.40
# 同一 markdown 文件最多保留几个 chunk，避免单页霸屏
RAG_MAX_CHUNKS_PER_FILE=2
# Hybrid 融合与重写
RAG_RRF_K=60
RAG_ENABLE_BM25=true
RAG_ENABLE_HYDE=false
# Prompt 里每个 chunk 的字符截断，以及是否把命中片段的相邻 chunk（+-N）一起拼入
RAG_CONTEXT_CHUNK_CHARS=700
RAG_CONTEXT_EXPAND_NEIGHBORS=1

# 生成层保护（prompt guard / 对比模板 / 引用合法性后校验）
# 有 context 时注入 guard 系统指令（字段级严格、来源合法、不跨实体传染）
RAG_ENABLE_PROMPT_GUARD=true
# 识别到对比/选型类意图时启用对比模板（动态维度、选型建议可选、资料缺口）
RAG_ENABLE_COMPARISON_TEMPLATE=true
# 对比模板退化阈值：归纳不出至少 N 个维度就回退通用模板
RAG_COMPARISON_MIN_DIMENSIONS=3
# 生成后对 answer 中引用的文件名做合法性校验（必须在命中来源集合内）
RAG_CITATION_POSTCHECK=true
# 发现非法来源时对 confidence 的扣分 (0~1)
RAG_CITATION_PENALTY=0.25

# /api/v1/search 自动路由（未指定 repo 时 LLM 在可见 KB 中选 1 个）
RAG_ROUTE_MIN_CONFIDENCE=0.5
RAG_ROUTE_PRESELECT_LIMIT=10

# API Token 明文加密密钥（Fernet，32 字节 URL-safe base64；
# 生成方式：python manage.py generate-token-key）。
# 配置后，用户在 /user/settings/tokens 列表里可以随时"显示并复制"完整 token。
# 留空：系统仍可创建/使用 token，但列表页无法回显完整明文。
API_TOKEN_ENC_KEY=

# 摄入并发
# 单文件 ingest 内页面生成阶段的 LLM 并发度
INGEST_LLM_CONCURRENCY=4
# 单文件 ingest 内 Qdrant 索引阶段的页面并发度
INGEST_INDEX_CONCURRENCY=4

# MinerU 文档解析服务
MINERU_API_URL=http://172.36.237.175:8000
MINERU_TIMEOUT=300

# MySQL 数据库
DB_HOST=
DB_PORT=3306
DB_NAME=llmwiki
DB_USER=
DB_PASSWORD=

# 部署服务器
DEPLOY_HOST=
DEPLOY_PORT=2234
DEPLOY_USER=root
DEPLOY_PASSWORD=

# Flask
# 生产/公测环境必须设置为随机长字符串，不能使用默认值
SECRET_KEY=change-me-to-a-random-string
DATA_DIR=./data
APP_BASE_URL=http://localhost:5000
WTF_CSRF_ENABLED=true

# SMTP / 找回密码
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_SSL=true
MAIL_FROM=
PASSWORD_RESET_EXPIRES=3600

# Admin
ADMIN_USERNAME=your_admin_username
SITE_NAME=Open LLM Wiki

# xAI Grok Search（用于构建测试知识库，见 scripts/build_llm_kb.py）
XAI_API_KEY=
