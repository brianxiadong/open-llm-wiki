# LLM 配置（对话/生成）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=16384

# Embedding 模型（向量化，可与 LLM 使用不同的服务）
EMBEDDING_API_BASE=http://your-embedding-server:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

# Qdrant 向量数据库
QDRANT_URL=http://your-qdrant-server:6333

# MinerU 文档解析服务
MINERU_API_URL=http://172.36.237.175:8000
MINERU_TIMEOUT=300

# MySQL 数据库
DB_HOST=
DB_PORT=3306
DB_NAME=llmwiki
DB_USER=
DB_PASSWORD=

# 部署服务器
DEPLOY_HOST=
DEPLOY_PORT=2234
DEPLOY_USER=root
DEPLOY_PASSWORD=

# Flask
SECRET_KEY=change-me-to-a-random-string
DATA_DIR=./data

# Admin
ADMIN_USERNAME=your_admin_username
SITE_NAME=Open LLM Wiki

# xAI Grok Search（用于构建测试知识库，见 scripts/build_llm_kb.py）
XAI_API_KEY=
